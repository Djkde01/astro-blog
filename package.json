{
  "name": "djkde-blog-astro",
  "type": "module",
  "version": "0.0.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.1.3",
      "onFail": "error"
    }
  },
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "preinstall": "node scripts/require-pnpm.mjs",
    "dev": "node scripts/require-pnpm.mjs && astro dev",
    "start": "node scripts/require-pnpm.mjs && astro dev",
    "build": "node scripts/require-pnpm.mjs && astro build",
    "preview": "node scripts/require-pnpm.mjs && astro preview",
    "astro": "node scripts/require-pnpm.mjs && astro"
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/rss": "^4.0.14",
    "@astrojs/sitemap": "^3.6.0",
    "@fontsource-variable/montserrat": "^5.0.17",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/json": "^2.2.306",
    "@justinribeiro/lite-youtube": "^1.7.1",
    "astro": "^5.16.6",
    "astro-icon": "^1.1.5",
    "postcss": "^8.4.31",
    "postcss-preset-env": "^9.1.4",
    "sanitize-html": "^2.11.0",
    "sharp": "^0.32.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "vite": "^7.3.0"
  }
}
