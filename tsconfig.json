{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "types": ["astro/client", "vite/client"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
